# Copy this file to .env (which is gitignored) and fill in real values locally,
# or set these as real environment variables at deploy time. Never commit .env.

# Required: the LLM the tool loop calls. Any non-empty placeholder works
# against a local vLLM endpoint (set OPENAI_BASE_URL too in that case).
OPENAI_API_KEY=sk-placeholder

# Optional: point at a self-hosted / vLLM Chat Completions endpoint instead of
# hosted OpenAI. Leave unset to use hosted OpenAI.
# OPENAI_BASE_URL=http://localhost:8000/v1

# Optional: raises the Semantic Scholar anonymous rate limit. Free key at
# https://www.semanticscholar.org/product/api#api-key. Leave unset to search
# anonymously (works, but 429s more often).
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: override agent name/networking defaults from config.py.
# AGENT_MODEL=gpt-4o-mini
# AGENT_A2A_HOST=0.0.0.0
# AGENT_A2A_PORT=9110
# AGENT_A2A_URL=
